PORT=3000

# MongoDB Atlas — prefer standard URI on Windows if mongodb+srv fails with querySrv ECONNREFUSED
# Standard (recommended on Windows):
# MONGODB_URI=mongodb://<user>:<password>@<host1>:27017,<host2>:27017,<host3>:27017/<db>?ssl=true&authSource=admin&replicaSet=<replicaSet>
#
# SRV (works when DNS SRV lookups succeed):
# MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<db>?retryWrites=true&w=majority

MONGODB_URI=
